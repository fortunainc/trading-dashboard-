# Trading Dashboard Environment Variables

# Application
APP_NAME=trading-dashboard
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# API Keys (Replace with your actual keys)
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_API_URL=https://api.tradier.com/v1
YAHOO_API_URL=https://query1.finance.yahoo.com/v8/finance/chart
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
ALPHA_VANTAGE_API_URL=https://www.alphavantage.co/query
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_API_URL=https://finnhub.io/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trading_dashboard
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=300
REDIS_MAX_CONNECTIONS=50

# Data Validation
STRICT_VALIDATION=true
CACHE_VALIDATED_ONLY=false

# Analysis Configuration
WATCHLIST=NVDA,META,TSLA,AAPL,GOOGL,AMZN,MSFT
MAX_SCALP_SETUPS=4
MAX_SWING_SETUPS=3
MIN_SCALP_SCORE=60
MIN_SWING_SCORE=60

# Time Configuration
TIMEZONE=America/New_York
MARKET_OPEN_TIME=09:30:00
MARKET_CLOSE_TIME=16:00:00
PREMARKET_START_TIME=04:00:00
AFTER_HOURS_END_TIME=20:00:00

# WebSocket
WS_PORT=8001
WS_RECONNECT_INTERVAL=5000

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# External Service Timeouts
TRADIER_TIMEOUT=10
YAHOO_TIMEOUT=10
ALPHA_VANTAGE_TIMEOUT=10
FINNHUB_TIMEOUT=10